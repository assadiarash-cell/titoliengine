{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    }
  },
  "env": {
    "TE_DATABASE_URL": "@te-database-url",
    "TE_ANTHROPIC_API_KEY": "@te-anthropic-api-key",
    "TE_SECRET_KEY": "@te-secret-key",
    "TE_CORS_ORIGINS": "@te-cors-origins",
    "TE_DEBUG": "false"
  }
}
